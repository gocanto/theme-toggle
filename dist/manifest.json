{
  "manifest_version": 3,
  "name": "Dark Mode - Lite",
  "description": "A compact dark-mode extension made by gocanto.sh with Vue and Tailwind CSS.",
  "version": "0.1.0",
  "homepage_url": "https://github.com/gocanto/ex-dark-mode-lite",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Dark Mode - Lite",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
