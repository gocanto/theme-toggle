{
  "manifest_version": 3,
  "name": "Dark Mode - Lite",
  "description": "A compact dark-mode extension built with Vue and Tailwind CSS.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Dark Mode - Lite",
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
