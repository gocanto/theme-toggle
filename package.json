{
  "name": "personal-dark-mode-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A compact MV3 dark-mode extension built with Vue, Vite+, Tailwind CSS, and shadcn-vue.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "vue-tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "format": "vp fmt",
    "format-all": "vp fmt --fix"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "@lucide/vue": "^1.23.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3",
    "vite-plus": "^0.2.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.18",
    "@types/node": "^24.10.2",
    "shadcn-vue": "^2.7.4",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.6"
  }
}
