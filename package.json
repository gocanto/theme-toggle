{
  "name": "dark-mode-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A compact MV3 dark-mode extension built with Vue, Vite+, Tailwind CSS, and shadcn-vue.",
  "packageManager": "pnpm@11.9.0",
  "imports": {
    "#scripts/*": "./scripts/*.ts"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "check:paths": "node scripts/check-paths.ts",
    "check": "pnpm run check:paths && pnpm run test && pnpm run typecheck && pnpm run build",
    "package:store": "node scripts/package-store.ts",
    "format": "node scripts/format.ts changed",
    "format-all": "node scripts/format.ts all"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lucide/vue": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3",
    "vite-plus": "^0.2.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.18",
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^4.1.9",
    "shadcn-vue": "^2.7.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  }
}
