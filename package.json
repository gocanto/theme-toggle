{
  "name": "ex-dark-mode-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Dark Mode - Lite Chrome extension and its marketing website.",
  "packageManager": "pnpm@11.9.0",
  "imports": {
    "#scripts/*": "./scripts/*.ts"
  },
  "scripts": {
    "dev": "pnpm --filter dark-mode-lite dev",
    "build": "pnpm --filter dark-mode-lite build",
    "preview": "pnpm --filter dark-mode-lite preview",
    "dev:web": "pnpm --filter @dml/web dev",
    "build:web": "pnpm --filter @dml/web build",
    "preview:web": "pnpm --filter @dml/web preview",
    "test": "pnpm --filter dark-mode-lite test",
    "test:coverage": "pnpm --filter dark-mode-lite test:coverage",
    "typecheck": "pnpm -r typecheck && tsc -p tsconfig.json --noEmit",
    "check:paths": "node scripts/check-paths.ts",
    "check": "pnpm run check:paths && pnpm run test && pnpm run typecheck && pnpm run build && pnpm run build:web",
    "package:store": "node scripts/package-store.ts",
    "format": "node scripts/format.ts changed",
    "format-all": "node scripts/format.ts all"
  },
  "devDependencies": {
    "@dml/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:"
  }
}
