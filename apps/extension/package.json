{
  "name": "dark-mode-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A compact MV3 dark-mode extension built with Vue, Vite+, Tailwind CSS, and shadcn-vue.",
  "scripts": {
    "dev": "vp dev --host 127.0.0.1",
    "build": "vp build",
    "preview": "vp preview --host 127.0.0.1",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
