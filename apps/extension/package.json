    "vue": "catalog:"
  },
  "devDependencies": {
    "@dml/tsconfig": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/chrome": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "shadcn-vue": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
